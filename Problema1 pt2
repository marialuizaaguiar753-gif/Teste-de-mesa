using System;
class Program
{
    static void Main()
    {
        Console.Write("Digite o valor presente: ");
        double valorPresente = double.Parse(Console.ReadLine());
        Console.Write("Digite a taxa de juros (%): ");
        double taxa = double.Parse(Console.ReadLine()) / 100;
        Console.Write("Digite o período (anos): ");
        int periodoAnos = int.Parse(Console.ReadLine());
        double valorF = valorPresente * Math.Pow((1 + taxa/100), periodoAnos);
        Console.WriteLine($"\nMOSTRAR RENDA: R$ {valorF: F2}");
    }
}
